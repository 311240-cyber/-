// 替換成你剛剛在 Google Apps Script 複製的網頁應用程式 URL
const GOOGLE_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbzisBnw2jYQUp2VWKvo4dTvHkB0w-7RTx4zGwREKpdsX3Gd-OOLwiJhWe2KqsiGPFZP/exec";

// 新增一個傳送資料到 Google 試算表的函式
function logToGoogleSheets(modeName) {
    const data = {
        mode: modeName === 'work' ? '工作專注' : '休息放鬆',
        status: '完成一個番茄鐘 🍅'
    };

    // 使用 fetch 發送 POST 請求
    fetch(GOOGLE_SCRIPT_URL, {
        method: "POST",
        mode: "no-cors", // 避免跨網域 (CORS) 瀏覽器報錯
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify(data)
    })
    .then(() => console.log("成功記錄到 Google 試算表！"))
    .catch(err => console.error("記錄失敗：", err));
}

// 修改原有的計時器邏輯
countdown = setInterval(() => {
    timeLeft--;
    updateDisplay(timeLeft);

    if (timeLeft <= 0) {
        clearInterval(countdown);
        isRunning = false;
        playAlarm();
        
        // 【新增】在時間到時，觸發傳送資料的功能
        logToGoogleSheets(currentMode);
        
        alert(currentMode === 'work' ? '工作結束！該休息一下囉 ☕' : '休息結束！準備專注工作 💪');
        resetTimer();
    }
}, 1000);
